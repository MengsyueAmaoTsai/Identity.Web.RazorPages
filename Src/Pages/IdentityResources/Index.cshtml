@page "/identity-resources"
@model ListIdentityResourcesViewModel
@{
    ViewData["Title"] = "Identity Resources";
}

<h1>Identity Resources</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Display Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var resource in Model.IdentityResources)
        {
            <tr>
                <td>@resource.Name</td>
                <td>@resource.DisplayName</td>
                <td>@resource.Description</td>
                <td>
                    <a asp-page="./details" asp-route-resourceId="@resource.Name">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
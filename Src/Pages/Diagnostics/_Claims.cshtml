@using System.Security.Claims

@model ClaimsPrincipal
@{
}

<fluent-card>
    <h4>Claims</h4>
</fluent-card>

<fluent-card>
    <table class="table">
        <tbody>
            <tr>
                <th>Type</th>
                <th>Value</th>
            </tr>
            @foreach (var claim in Model.Claims)
            {
                <tr>
                    <td>@claim.Type</td>
                    <td>@claim.Value</td>
                </tr>
            }
        </tbody>
    </table>
</fluent-card>

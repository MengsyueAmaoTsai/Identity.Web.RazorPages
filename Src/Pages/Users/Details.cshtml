@page "/users/{userId}"

@model UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
}

<h1>User Details</h1>

<div class="user-profile">
    <div class="avatar">
        <img src="@Model.User.AvatarUrl" alt="@Model.User.Name" />
    </div>

    <div class="user-info">
        <div class="user-name">@Model.User.Name</div>
        <div class="user-email">@Model.User.Email</div>
    </div>
</div>


<style>
    .user-profile {
        display: flex;
    }

    .avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        margin-right: 20px;
    }

    .user-info {
        display: flex;
        flex-direction: column;
    }

    .user-name {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .user-email {
        font-size: 14px;
        color: #666;
    }
</style>
@page "/stay-signed-in"

@model StaySignedInViewModel

@{
    ViewData["Title"] = "Stay signed in?";
}

<div>
    @await Html.PartialAsync("_FormImage")
    @await Html.PartialAsync("_IdentityBanner", Model.EmailAddress)

    <div class="page-content">
        <form id="post-redirect-form"></form>

        <div class="form-wrapper-animation">
            <form method="post" spellcheck="false" autocomplete="off">
                @await Html.PartialAsync("_FormTitle", ViewData["Title"])

                <div class="form-description-wrapper">
                    <div class="form-description">Stay signed in so you don't have to sign in again next time.</div>
                </div>

                <div>
                    <div class="dont-show-again-row">
                        <div class="dont-show-again-wrapper">
                            <label class="dont-show-again-text" asp-for="DontShowAgain">
                                <input class="dont-show-again" type="checkbox" asp-for="DontShowAgain">
                                <span>Don't show this again</span>
                            </label>
                        </div>
                    </div>

                    <div class="button-container-row">
                        <div class="button-container">
                            <div class="button-secondary-wrapper">
                                <button class="button-secondary" type="submit" name="StaySignedIn" value="false">No</button>
                            </div>

                            <div class="button-primary-wrapper">
                                <button class="button-primary" type="submit" name="StaySignedIn" value="true">Yes</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .dont-show-again-row {
        min-height: 1px;
        margin-left: 0px;
        margin-right: 0px;
        display: inline-block;
        width: 100%;
        margin-bottom: 36px;
    }

    .dont-show-again-wrapper {
        position: relative;
        margin-bottom: 16px;
        margin-top: 12px;
        display: block;
    }

    .dont-show-again-text {
        min-height: 20px;
        padding-left: 28px;
        cursor: pointer;
        display: inline-block;
        max-width: 100%;
    }

    .dont-show-again {
        font-weight: inherit;
        font-family: inherit;
        font-size: inherit;
        line-height: inherit;
        max-width: 100%;
        margin: 0px;
        width: 20px;
        height: 20px;
        box-sizing: border-box;
        padding: 0px;
        position: absolute;
        margin-left: -28px;
    }
</style>
@page "/identity/sign-in"

@model SignInViewModel

@{
    ViewData["Title"] = "Sign In";
}

<div>@ViewData["Title"]</div>

<div>
    <input type="email" asp-for="EmailAddress"/>
</div>

<div>
    <div>
        No account? 
        <a asp-page="../signUp/index">Create one!</a>
    </div>
    <div>
        <a asp-page="../resetPassword/index">Can't access your account?</a>
    </div>
</div>

<form method="post">
    <div class="row-buttons">
        <input class="button-secondary" type="button" value="Back" />
        <input class="button-primary" type="submit" value="Next" />
    </div>
</form>

<div>
    Sign-in options
</div>
@page "/sign-in"

@model SignInViewModel

@{
    ViewData["Title"] = "Sign in";
}

<div>
    <form method="post">
        <div asp-validation-summary="All"></div>
        <input asp-for="EmailAddress" type="email">

        <input type="submit" value="Next">
    </form>
</div>

@section Scripts {
    <partial name="_ClientValidation" />
}
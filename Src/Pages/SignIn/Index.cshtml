@page "/sign-in"
@model SignInViewModel 

@{
    ViewData["Title"] = "Sign in";
}

<div>
    <form method="post" class="sign-in-form" spellcheck="false" autocomplete="off" novalidate>
        <div class="outer">
            <div class="main-section">
                <div class="middle">
                    <div class="lightbox">
                        <div class="lightbox-cover">
                        </div>

                        <div>
                            <img class="logo"
                                 role="img"
                                 pngsrc="https://aadcdn.msauth.net/shared/1.0/content/images/microsoft_logo_ea19b2112f4dfd8e90b4505ef7dcb4f9.png"
                                 svgsrc="https://aadcdn.msauth.net/shared/1.0/content/images/microsoft_logo_564db913a7fa0ca42727161c6d031bef.svg"
                                 src="https://aadcdn.msauth.net/shared/1.0/content/images/microsoft_logo_564db913a7fa0ca42727161c6d031bef.svg"
                                 alt="Richill Capital">
                        </div>

                        <div role="main">
                            <div class="pagination-view">
                                <div class="form-row form-title">
                                    <div role="heading">@ViewData["Title"]</div>
                                </div>

                                <div class="form-row">
                                    <div role="alert">
                                        <div class="email-error" asp-validation-summary="All"></div>
                                    </div>

                                    <div class="form-group">
                                        <div class="email-address-wrapper">
                                            <input asp-for="EmailAddress" class="email-address" type="email" placeholder="Email, phone, or Skype" maxlength="113">
                                        </div>
                                    </div>
                                </div>

                                <div class="form-row">
                                    <div class="links-container">
                                        <div class="form-group">
                                            No account? <a class="link" asp-page="/signUp/index">Create one!</a>
                                        </div>
                                        <div class="form-group">
                                            <a class="link" asp-page="/password/reset/index">Can't access your account?</a>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-row">
                                    <div class="buttons-container">
                                        <div class="button-wrapper">
                                            <input class="secondary-button" type="button" value="Back">
                                        </div>

                                        <div class="button-wrapper">
                                            <input class="primary-button" type="submit" value="Next">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="footer">
                <div class="footer-links">
                    <a class="footer-link" href="#">Terms of use</a>
                    <a class="footer-link" href="#">Privacy & cookies</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}

<style>
    .sign-in-form {
        min-height: 1px;
    }

    .outer {
        display: table;
        position: absolute;
        height: 100%;
        width: 100%;
    }

    .main-section {
        display: table-row;
        height: 100%;
    }

    .middle {
        display: table-cell;
        vertical-align: middle;
    }

    .lightbox {
        margin-left: auto;
        margin-right: auto;
        position: relative;
        max-width: 440px;
        width: calc(100% - 40px);
        padding: 44px;
        background-color: #fff;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
        min-width: 320px;
        min-height: 338px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .lightbox-cover {
        background-color: white;
        opacity: 0;
        filter: alpha(opacity = 0);
        z-index: -1;
        height: 100%;
        width: 100%;
        position: absolute;
        top: 0;
        left: 0;
    }

    .logo {
        border: 0;
        vertical-align: middle;
        max-width: 256px;
        height: 24px;
    }

    .pagination-view {
        position: relative;
        min-height: 206px;
    }

    .form-title {
        line-height: 1.75rem;
        color: #1b1b1b;
        font-size: 1.5rem;
        font-weight: 600;
        padding: 0;
        margin-top: 16px;
        margin-bottom: 12px;
        font-family: "Segoe UI", "Helvetica Neue", "Lucida Grande", "Roboto", "Ebrima", "Nirmala UI", "Gadugi", "Segoe Xbox Symbol", "Segoe UI Symbol", "Meiryo UI", "Khmer UI", "Tunga", "Lao UI", "Raavi", "Iskoola Pota", "Latha", "Leelawadee", "Microsoft YaHei UI", "Microsoft JhengHei UI", "Malgun Gothic", "Estrangelo Edessa", "Microsoft Himalaya", "Microsoft New Tai Lue", "Microsoft PhagsPa", "Microsoft Tai Le", "Microsoft Yi Baiti", "Mongolian Baiti", "MV Boli", "Myanmar Text", "Cambria Math";
    }

    .form-row {
        margin-right: 0;
        margin-left: 0;
    }

    .form-group {
        position: relative;
        min-height: 1px;
        padding-left: 2px;
        padding-right: 2px;
        margin-bottom: 16px;
    }
    
    .links-container {
        font-size: .8125rem;
    }

    .link {
        background-color: transparent;
        text-decoration: none;
        color: #0067B8;
    }

    .email-error {
        position: relative;
        min-height: 1px;
        padding-left: 2px;
        padding-right: 2px;
        color: #E81123;
    }

    .email-address-wrapper {
        width: 100%;
        position: relative;
    }

    .email-address {
        display: block;
        width: 100%;
        background-image: none;
        direction: ltr;
        text-align: left;
        -webkit-border-radius: 0;
        background-color: transparent;
        border-top-width: 0;
        border-left-width: 0;
        border-right-width: 0;
        padding-left: 0;
        border-color: rgba(0, 0, 0, 0.6);
        height: 36px;
        outline: none;
        padding: 6px 10px;
        border-width: 1px;
        border-style: solid;        
    }

    .buttons-container {
        width: 100%;
        float: left;
        min-height: 1px;
        padding-left: 0;
        padding-right: 0;        
        position: absolute;
        bottom: 0;
        right: 0;
        text-align: right;
    }
    
    .button-wrapper {
        display: inline-block;
    }

    .primary-button {
        margin: 0;
        font: inherit;
        font-family: inherit;
        font-size: inherit;
        -webkit-appearance: button;
        cursor: pointer;
        padding: 4px 12px 4px 12px;
        position: relative;
        max-width: 100%;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        vertical-align: middle;
        text-overflow: ellipsis;
        touch-action: manipulation;
        min-width: 108px;
        line-height: normal;
        min-height: 32px;
        margin-top: 0;
        margin-bottom: 0;
        color: #FFF;
        background-color: #0067B8;
        border-color: #0067B8;
        display: block;
        width: 100%;
    }

    .secondary-button{
        padding: 4px 12px 4px 12px;
        position: relative;
        max-width: 100%;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        vertical-align: middle;
        text-overflow: ellipsis;
        touch-action: manipulation;
        color: #000;
        border-style: solid;
        border-width: 2px;
        border-color: transparent;
        min-height: 32px;
        border: none;        
        background-color: rgba(0, 0, 0, 0.2);
        min-width: 108px;
        line-height: normal;
        margin-top: 0;
        margin-bottom: 0;
        display: block;
        width: 100%;        
    }

    .footer {
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        overflow: visible;
        z-index: 99;
        clear: both;
        min-height: 28px;
    }

    .footer-links {
        color: rgba(0, 0, 0, 0.7);
        font-size: 13px;
        margin: 0;
        float: right;
    }

    .footer-link {
        box-sizing: border-box;
        background-color: transparent;
        text-decoration: none;
        color: #000;
        font-size: 12px;
        line-height: 28px;
        white-space: nowrap;
        display: inline-block;
        margin-left: 8px;
        margin-right: 8px;
    }

    .validation-summary ul {
        list-style-type: none; /* �����I�Ÿ� */
        padding: 0; /* ��������Z */
    }
</style>
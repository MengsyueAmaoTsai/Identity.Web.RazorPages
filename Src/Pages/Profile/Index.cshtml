@page "/profile"

@model ProfileViewModel

@{
    ViewData["Title"] = "Your profile";

    List<(string Text, string Page)> contentFooterLinks =
    [
        ("Privacy & cookies", "/index"),
        ("Terms of use", "/index"),
        ("Feedback", "/index"),
        ("Richill Capital 2024", "/index"),
    ];
}

<div>
    Side bar
</div>

<div class="css-238">
    <main id="MainContentLading" role="main">
        <div class="css-239">
            <div style="text-overflow: ellipsis; padding: 0px 0px 4px; min-height: 100vg;">
                <div class="css-240">
                    <div class="page-header">
                        <div class="page-header-inner">
                            <div class="page-header-left">
                                <div class="css-177">
                                    <div>
                                        <div>
                                            <div style="position: relative">
                                                <div>
                                                    <div role="navigation" class="root-178">
                                                        <div>
                                                            <ol class="list-179">
                                                                <li class="list-item-180">
                                                                    <div class="css-284">
                                                                        <span class="page-header-title-wrapper">
                                                                            <h1 class="page-header-title">Your info</h1>
                                                                        </span>
                                                                    </div>
                                                                </li>
                                                            </ol>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="page-header-right">
                                <div class="css-176">
                                    <div class="root-251">
                                        <div class="data-wrapper">
                                            <div class="css-254">
                                                <div class="css-397">
                                                    @await Html.PartialAsync("_ChangePasswordButton")
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="page-middle">
                        @await Html.PartialAsync("_MessageBar")
                    </div>

                    <div class="page-content">
                        <div class="sections-container">
                            @await Html.PartialAsync("_PersonalInfoSection")
                            @await Html.PartialAsync("_UserInfoSection", Model.CurrentUser.Email)
                        </div>
                    </div>
                </div>
            </div>

            <footer id="ContentFooter">
                <div class="content-footer-base">
                    <a></a>
                    <a></a>
                    <a></a>
                    <nav class="content-footer-links">
                        <ul class="content-footer-link-list">
                            @foreach (var link in contentFooterLinks)
                            {
                                <li class="content-footer-links-item">
                                    <a asp-page="@link.Page" class="content-footer-link">
                                        @link.Text
                                    </a>
                                </li>
                            }
                            <li></li>
                        </ul>
                    </nav>
                </div>
            </footer>
        </div>
    </main>
</div>


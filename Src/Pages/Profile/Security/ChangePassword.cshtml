@page "/profile/security/change-password"
@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<h2>
    Change Password
</h2>

<form method="post">
    <div>
        <label asp-for="CurrentPassword" class="form-label"></label>
        <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" aria-required="true" />                
    </div>

    <div>
        <label asp-for="NewPassword" class="form-label"></label>
        <input asp-for="NewPassword" class="form-control" autocomplete="current-password" aria-required="true" />        
    </div>

    <div>
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="current-password" aria-required="true" />
    </div>

    <button type="submit">Save</button>
    <a asp-page="./index">Cancel</a>
</form>
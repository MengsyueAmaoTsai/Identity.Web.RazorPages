
@{
    ViewData["Title"] = "Profile";
    Layout = "_ProfileLayout";

    List<(string Text, string Page, string Image)> items = 
    [
        ("Overview", "/profile/index", ""),
        ("Services & subscriptions", "/profile/devices/index", ""),
        ("Devices", "/profile/devices/index", ""),
        ("Security", "/profile/security/index", ""),
    ];
}

<div id="SideNav">
    <div style="display: flex; flex-flow: column; width: auto; height: auto; box-sizing: border-box;">
        <div style="position: fixed; height: calc(100% - 48px); z-index: 5; text-overflow: ellipsis;">
            <div class="side-nav-root">
                <nav role="navigation" class="side-nav-wrapper">
                    <div class="side-nav-container">
                        <div role="presentation">
                            <ul class="side-nav-items">
                                <div role="group">
                                    <li role="presentation">
                                        @await Html.PartialAsync("_ProfileButton")
                                    </li>

                                    @foreach (var item in items)
                                    {
                                        <li class="side-nav-item-wrapper" role="presentation">
                                            @await Html.PartialAsync("_SideNavItem", item)
                                        </li>
                                    }
                                </div>
                            </ul>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
    </div>
</div>



<style>
    #SideNav {
        color: rgb(50, 49, 48);
        background: rgb(242, 242, 242);
        font-family: "Segoe UI Variable Text", "Segoe UI", "Segoe UI Web (West European)", "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, "Helvetica Neue", sans-serif;
        font-weight: 400;
        font-size: 14px;
        -webkit-font-smoothing: antialiased;    
        text-overflow: ellipsis;    
    }

    .side-nav-root {
        position: relative;
        z-index: 1;
        flex: 0 0 auto;
        height: 100%;
    }
    .side-nav-wrapper {
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        padding-left: 10px;
        padding-top: 24px;
    }

    .side-nav-container {
        width: calc(280px + var(--scrollbar-width));
        background-color: rgb(242, 242, 242);
        color: rgb(50, 49, 48);
        transition-property: width;
        transition-duration: 0s;
        font-size: 14px;
        overflow: hidden scroll;
        margin-inline-end: calc(var(--scrollbar-width)* -1);
        height: 100%;
        max-height: 100%;
        max-width: 250px;
        user-select: none;        
    }

    .side-nav-items {
        margin: 0px;
        padding: 0px;
        list-style: none;
    }

    .side-nav-item-wrapper {
        margin: 0;
        padding: 0;
        list-style: none;
    }
</style>